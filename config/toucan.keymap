/*
 * Toucan per-board keymap.
 *
 * Hosts urob's ported config (config/base.keymap + combos.dtsi + mouse.dtsi) on the
 * toucan's 42-key (3x6 + 3-thumb) layout, with a QWERTY base layer.
 *
 * Layout strategy
 * ---------------
 *   - urob's 5 logical columns map onto the toucan's INNER 5 columns. zmk-helpers'
 *     42.h labels them LT0..LT4 etc. -> positions 1-5 / 6-10 / 25-29 / 30-34, exactly
 *     where urob's keys land. The toucan's OUTER pinky column (positions 0/12/24 left,
 *     11/23/35 right) is filled below with Tab / Ctrl / Shift | Bspc / ' / Esc.
 *   - urob uses 2 thumbs/side; the toucan has 3. urob's 2 thumbs (LH/RH) sit on the
 *     inner two thumbs; the SPARE OUTER thumb on each side switches to the toucan's
 *     own NAV/SYM/ADJ layers (Bluetooth picker, ZMK Studio unlock, F-keys / media).
 *
 * Layers
 * ------
 *   urob's base.keymap defines 0..5 (Base, Nav, Fn, Num, Sys, Mouse). The toucan's
 *   native layers are appended after -> 6 (NAV), 7 (SYM), 8 (ADJ). Holding both spare
 *   outer thumbs activates NAV+SYM -> the ADJ tri-layer (mirrors stock toucan).
 *
 * First pass: leader key dropped; combos kept on urob's exact positions (may misfire
 * on some QWERTY bigrams); urob's nav/sym overlap the toucan's NAV/SYM (kept anyway).
 */

#define CONFIG_WIRELESS  // toucan is BLE: enable urob's Bluetooth keys on his Sys layer.

// Toucan's native layers, appended after urob's 0..5.
#define TOU_NAV 6
#define TOU_SYM 7
#define TOU_ADJ 8

// Map urob's logical layout (5 cols + 2 thumbs/side) onto the toucan's 42 keys.
// The outer pinky column and the spare outer thumb (toucan layer switches) are
// hardcoded here, so they persist across all of urob's layers.
#define ZMK_BASE_LAYER(name, LT, RT, LM, RM, LB, RB, LH, RH)                   \
    ZMK_LAYER(name,                                                            \
        &kp TAB     LT RT &kp BSPC                                             \
        &kp ESC     LM RM &kp SQT                                              \
        &kp LSHFT   LB RB &kp LCTRL                                              \
        &mo TOU_NAV LH RH &mo TOU_SYM                                          \
    )

#include "zmk-helpers/key-labels/42.h"

// zmk-helpers v0.3's 42.h defines the per-key labels (LT0..RH2) but not these
// aggregates (added upstream after v0.3). urob's base.keymap needs them for the
// bilateral homerow mods (hold-trigger-key-positions = <KEYS_R THUMBS> etc.).
// Guarded so a newer zmk-helpers (which already defines them) won't clash.
#ifndef KEYS_L
#define KEYS_L LT0 LT1 LT2 LT3 LT4 LT5 LM0 LM1 LM2 LM3 LM4 LM5 LB0 LB1 LB2 LB3 LB4 LB5
#define KEYS_R RT0 RT1 RT2 RT3 RT4 RT5 RM0 RM1 RM2 RM3 RM4 RM5 RB0 RB1 RB2 RB3 RB4 RB5
#define THUMBS_L LH0 LH1 LH2
#define THUMBS_R RH0 RH1 RH2
#define THUMBS THUMBS_L THUMBS_R
#endif

#include "base.keymap"

/* ───────────────────────── Toucan's native layers ─────────────────────────
 * Kept verbatim from the stock toucan keymap (with a couple of stock typos
 * fixed) so the toucan hardware controls stay reachable. Defined after
 * base.keymap, so these get layer indices 6, 7, 8. Defined as full 42-key
 * layers (NOT via ZMK_BASE_LAYER). */

ZMK_LAYER(toucan_nav,
    &kp TAB     &kp N1          &kp N2       &kp N3       &kp N4       &kp N5         &kp N6   &kp N7   &kp N8 &kp N9    &kp N0 &kp BSPC
    &bt BT_CLR  &bt BT_SEL 0    &bt BT_SEL 1 &bt BT_SEL 2 &bt BT_SEL 3 &bt BT_SEL 4   &kp LEFT &kp DOWN &kp UP &kp RIGHT &trans &trans
    &kp LSHFT   &studio_unlock  &trans       &trans       &trans       &trans         &trans   &trans   &trans &trans    &trans &trans
                                             &trans       &trans       &kp SPACE      &kp RET  &trans   &trans
)

ZMK_LAYER(toucan_sym,
    &kp TAB   &kp EXCL &kp AT &kp HASH &kp DLLR &kp PRCNT   &kp CARET &kp AMPS  &kp KP_MULTIPLY &kp LPAR &kp RPAR &kp BSPC
    &kp LCTRL &trans   &trans &trans   &trans   &trans      &kp MINUS &kp EQUAL &kp LBKT        &kp RBKT &kp BSLH &kp GRAVE
    &kp LSHFT &trans   &trans &trans   &trans   &trans      &kp UNDER &kp PLUS  &kp LBRC        &kp RBRC &kp PIPE &kp TILDE
                                       &trans   &trans       &kp SPACE   &kp RET   &trans   &trans
)

ZMK_LAYER(toucan_adj,
    &trans    &trans &kp F7 &kp F8 &kp F9 &kp F12   &kp C_VOL_DN &kp C_MUTE &kp C_VOL_UP &trans &trans &kp BSPC
    &kp LCTRL &trans &kp F4 &kp F5 &kp F6 &kp F11   &trans       &trans     &trans       &trans &trans &trans
    &kp LSHFT &trans &kp F1 &kp F2 &kp F3 &kp F10   &trans       &trans     &trans       &trans &trans &trans
                            &trans &trans &kp SPACE   &kp RET &trans &trans
)

ZMK_CONDITIONAL_LAYER(toucan_tri, TOU_NAV TOU_SYM, TOU_ADJ) // NAV + SYM --> ADJ.
